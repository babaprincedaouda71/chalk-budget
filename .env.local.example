# Base Upstash Redis (optionnelle) pour la synchronisation multi-appareils.
# À provisionner via le Marketplace Vercel (intégration Upstash — les
# variables sont alors injectées automatiquement) ou sur console.upstash.com.
# Sans ces variables, la sync est indisponible mais l'app reste 100 % locale.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
