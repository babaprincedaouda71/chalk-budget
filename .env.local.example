# Clé API Google Gemini (optionnelle) pour l'« ajout magique » par IA.
# À obtenir sur https://aistudio.google.com/apikey puis copier ce fichier
# en .env.local (jamais commité). Sans clé, le parseur local par mots-clés
# prend le relais — l'application fonctionne entièrement sans.
GEMINI_API_KEY=

# Base Upstash Redis (optionnelle) pour la synchronisation multi-appareils.
# À provisionner via le Marketplace Vercel (intégration Upstash — les
# variables sont alors injectées automatiquement) ou sur console.upstash.com.
# Sans ces variables, la sync est indisponible mais l'app reste 100 % locale.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=